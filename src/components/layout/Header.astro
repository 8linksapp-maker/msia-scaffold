---
import { readData } from '../../lib/readData';
import { getCollection } from 'astro:content';

const siteConfig = readData('siteConfig.json');
const menuItems: any[] = readData('menu.json', { items: [] }).items || [];

const posts = await getCollection('blog');
const categoriesFromPosts = [...new Set(posts.map(p => p.data.category).filter(Boolean))];
const categoriesData = readData('categories.json', []);
const finalCategoriesData = Array.isArray(categoriesData) ? categoriesData : [];
const allCategories = finalCategoriesData.length > 0 ? finalCategoriesData : categoriesFromPosts;

const slugify = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
---

<header class="bg-nav text-white sticky top-0 z-40">
  <div class="container-x flex items-center justify-between h-[72px] gap-6">
    <a href="/" class="flex items-center gap-2 no-underline">
      {siteConfig.logo ? (
        <img src={siteConfig.logo} alt={siteConfig.name} class="h-9 w-auto" />
      ) : (
        <span class="font-display text-2xl font-bold text-white tracking-tight">{siteConfig.name}</span>
      )}
    </a>

    <nav class="hidden lg:flex items-center gap-8 flex-1 justify-center" aria-label="Principal">
      {menuItems.map((item: any) => (
        item.showCategories ? (
          <div class="relative group">
            <a href={item.href} class="text-sm font-medium text-white/85 hover:text-white transition-colors flex items-center gap-1">
              {item.label}
              <svg width="10" height="10" viewBox="0 0 10 10" class="opacity-60"><path d="M1 3l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </a>
            <ul class="absolute top-full left-1/2 -translate-x-1/2 mt-1 min-w-[200px] bg-surface rounded-md shadow-card-hover opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all py-2 z-50">
              <li><a href={item.href} class="block px-4 py-2 text-sm text-ink hover:text-primary">Todos os artigos</a></li>
              {allCategories.map((cat: string) => (
                <li><a href={`/categoria/${slugify(cat)}`} class="block px-4 py-2 text-sm text-ink hover:text-primary">{cat}</a></li>
              ))}
            </ul>
          </div>
        ) : (
          <a href={item.href} class="text-sm font-medium text-white/85 hover:text-white transition-colors">{item.label}</a>
        )
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <button id="search-toggle" class="w-10 h-10 flex items-center justify-center rounded-md text-white/85 hover:text-white hover:bg-white/10 transition-colors" aria-label="Buscar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <button id="menu-toggle" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-md text-white/85 hover:text-white hover:bg-white/10 transition-colors" aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>

  <div class="h-[2px] bg-primary"></div>

  <div id="search-popup" class="hidden fixed inset-0 bg-nav/95 backdrop-blur-md z-50 items-center justify-center p-6">
    <button id="search-close" class="absolute top-6 right-6 text-white/85 hover:text-white" aria-label="Fechar busca">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <form action="/search" class="w-full max-w-prose-lg">
      <div class="text-white/60 text-sm mb-3 uppercase tracking-wider">Pressione ESC para fechar</div>
      <input type="search" name="q" placeholder="Buscar artigos…" class="w-full bg-transparent border-b-2 border-white/30 focus:border-primary outline-none text-white text-3xl font-display py-3 placeholder:text-white/40" autofocus />
    </form>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden bg-nav border-t border-white/10">
    <nav class="container-x py-4 space-y-2">
      {menuItems.map((item: any) => (
        <a href={item.href} class="block py-2 text-white/85 hover:text-white">{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<script is:inline>
  (function() {
    const toggle = document.getElementById('search-toggle');
    const close  = document.getElementById('search-close');
    const popup  = document.getElementById('search-popup');
    if (toggle && close && popup) {
      toggle.addEventListener('click', () => { popup.classList.remove('hidden'); popup.classList.add('flex'); popup.querySelector('input')?.focus(); });
      close.addEventListener('click', () => { popup.classList.add('hidden'); popup.classList.remove('flex'); });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !popup.classList.contains('hidden')) {
          popup.classList.add('hidden'); popup.classList.remove('flex');
        }
      });
    }
    const menuBtn = document.getElementById('menu-toggle');
    const mobile  = document.getElementById('mobile-menu');
    if (menuBtn && mobile) {
      menuBtn.addEventListener('click', () => mobile.classList.toggle('hidden'));
    }
  })();
</script>
