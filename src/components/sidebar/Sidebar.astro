---
import { getCollection } from 'astro:content';
import { readData } from '../../lib/readData';

const siteConfig = readData('siteConfig.json');
const homeData = readData('home.json', {});

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a: any, b: any) => {
    const da = new Date(a.data.pubDate || a.data.date || 0).getTime();
    const db = new Date(b.data.pubDate || b.data.date || 0).getTime();
    return db - da;
  })
  .slice(0, 4);

const highlight = (homeData as any)?.sidebar?.highlight || {
  label: 'Em destaque',
  title: 'Newsletter semanal',
  description: 'Receba uma curadoria do que rolou de mais importante esta semana. Sem spam, só conteúdo.',
  cta: 'Quero receber',
  href: '#newsletter',
};

const palette = ['#2d8c4f', '#6c3eb6', '#1e73be', '#d97706', '#0d9488', '#be185d', '#475569'];
---

<aside class="space-y-6 sticky top-24">
  <div class="widget widget-highlight">
    <div class="widget-title">{highlight.label || 'Em destaque'}</div>
    <h3 class="text-2xl font-display font-semibold leading-tight mb-3 text-white">
      {highlight.title}
    </h3>
    <p class="text-sm leading-relaxed text-white/85 mb-5">
      {highlight.description}
    </p>
    <a href={highlight.href || '#'} class="btn btn-primary !bg-nav hover:!bg-black no-underline">
      {highlight.cta || 'Saiba mais'}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>

  <div class="widget">
    <div class="widget-title">Posts recentes</div>
    <ul class="space-y-4">
      {recentPosts.map((post: any, i: number) => {
        const data = post.data;
        const slug = post.slug ?? post.id;
        const cover = data.cover || data.coverImage || data.image;
        const colorBg = palette[i % palette.length];
        return (
          <li>
            <a href={`/${slug}`} class="flex items-start gap-3 no-underline group">
              {cover ? (
                <img src={cover} alt={data.title} class="w-14 h-14 rounded object-cover flex-shrink-0" loading="lazy" />
              ) : (
                <div class="w-14 h-14 rounded flex items-center justify-center flex-shrink-0 text-white" style={`background: ${colorBg}`}>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                </div>
              )}
              <div class="min-w-0">
                <h4 class="text-sm font-semibold leading-snug text-primary group-hover:text-primary-dark line-clamp-2 font-sans">
                  {data.title}
                </h4>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</aside>
