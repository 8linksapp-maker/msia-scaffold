---
interface Props {
  post: any; // CollectionEntry<'blog'> mas flexível pra dummy data
  index?: number;
  showNumber?: boolean;
}

const { post, index = 0, showNumber = true } = Astro.props;
const slugify = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

const data = post.data ?? post;
const slug = post.slug ?? post.id ?? slugify(data.title);
const url = `/${slug}`;
const cover = data.cover || data.coverImage || data.image || '';
const title = data.title || 'Sem título';
const excerpt = data.description || data.excerpt || '';
const category = data.category || 'Geral';
const date = data.pubDate || data.date || data.publishedAt;
const author = data.author || '';

// Cores fallback pra thumb (caso não tenha cover) — paleta variada estilo Marketer
const palette = [
  { bg: '#2d8c4f', icon: 'rocket' },
  { bg: '#6c3eb6', icon: 'send' },
  { bg: '#1e73be', icon: 'shield' },
  { bg: '#d97706', icon: 'lightbulb' },
  { bg: '#0d9488', icon: 'globe' },
  { bg: '#be185d', icon: 'star' },
  { bg: '#475569', icon: 'briefcase' },
];
const colorIndex = (title.length + (category?.length || 0)) % palette.length;
const fallbackColor = palette[colorIndex];

const iconPaths: Record<string, string> = {
  rocket:    'M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09zM12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z',
  send:      'M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z',
  shield:    'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  lightbulb: 'M9 18h6M10 22h4M12 2a7 7 0 00-4 12.7c.5.4.8 1 .9 1.6.1.5.5.7 1 .7h4.2c.5 0 .9-.2 1-.7.1-.6.4-1.2.9-1.6A7 7 0 0012 2z',
  globe:     'M12 2a10 10 0 100 20 10 10 0 000-20zM2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z',
  star:      'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
  briefcase: 'M20 7H4a2 2 0 00-2 2v11a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16',
};

function fmtDate(d: any): string {
  if (!d) return '';
  const dt = new Date(d);
  if (isNaN(dt.getTime())) return '';
  return dt.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<article class={`post-card animate-fade-up stagger-${(index % 6) + 1}`}>
  {showNumber && index < 9 && (
    <span class="post-card-num">{index + 1}</span>
  )}

  <div class="p-6 md:p-8 relative z-10">
    {category && (
      <a href={`/categoria/${slugify(category)}`} class="cat-pill no-underline mb-3 hover:opacity-80">
        {category}
      </a>
    )}

    <h2 class="text-2xl md:text-3xl font-display font-semibold leading-tight mb-2">
      <a href={url} class="text-ink no-underline hover:text-primary transition-colors">
        {title}
      </a>
    </h2>

    {date && (
      <div class="text-xs uppercase tracking-wider text-ink-faint mb-5 font-medium">
        {fmtDate(date)}{author && <span class="opacity-50"> · {author}</span>}
      </div>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-[160px_1fr] gap-5 items-start">
      {cover ? (
        <a href={url} class="block">
          <img src={cover} alt={title} class="w-full sm:w-40 aspect-square object-cover rounded" loading="lazy" />
        </a>
      ) : (
        <a href={url} class="block">
          <div class="post-thumb-color w-full sm:w-40" style={`background: ${fallbackColor.bg}`}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[fallbackColor.icon]} />
            </svg>
          </div>
        </a>
      )}

      <div>
        {excerpt && (
          <p class="text-base text-ink-muted leading-relaxed line-clamp-3 mb-4">
            {excerpt}
          </p>
        )}
        <a href={url} class="btn btn-primary no-underline">
          Ler mais
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </div>
</article>
