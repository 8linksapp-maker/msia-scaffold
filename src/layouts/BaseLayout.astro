---
import '../styles/global.css';
import { readData } from '../lib/readData';
import HeadPlugins from '../plugins/_slots/HeadPlugins.astro';
import BodyEndPlugins from '../plugins/_slots/BodyEndPlugins.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const siteConfig = readData('siteConfig.json');
const pluginsConfig = readData('pluginsConfig.json', {});
const gscVerificationTag = (pluginsConfig as any)?.searchConsole?.verificationTag?.trim() || '';

// CMS pode customizar cores e fontes via siteConfig.theme — passamos como CSS vars no <html>
const primaryHex = siteConfig.theme?.primary || '#1e73be';
const primaryDarkHex = siteConfig.theme?.primaryDark || '';
const navHex = siteConfig.theme?.dark || '#141416';
const fontDisplay = siteConfig.theme?.fontDisplay || 'Fraunces';
const fontBody = siteConfig.theme?.fontBody || 'Outfit';

function hexToRgbTriplet(hex: string): string {
  const h = hex.replace('#', '').trim();
  if (h.length !== 6) return '30 115 190';
  const r = parseInt(h.substring(0, 2), 16);
  const g = parseInt(h.substring(2, 4), 16);
  const b = parseInt(h.substring(4, 6), 16);
  return `${r} ${g} ${b}`;
}
function darken(hex: string, amount = 0.15): string {
  const h = hex.replace('#', '').trim();
  if (h.length !== 6) return hex;
  const r = Math.round(parseInt(h.substring(0, 2), 16) * (1 - amount));
  const g = Math.round(parseInt(h.substring(2, 4), 16) * (1 - amount));
  const b = Math.round(parseInt(h.substring(4, 6), 16) * (1 - amount));
  return `${r} ${g} ${b}`;
}
function soften(hex: string): string {
  // mistura com branco pra criar tom soft (highlight box)
  const h = hex.replace('#', '').trim();
  if (h.length !== 6) return '226 240 251';
  const r = Math.round(parseInt(h.substring(0, 2), 16) * 0.12 + 255 * 0.88);
  const g = Math.round(parseInt(h.substring(2, 4), 16) * 0.12 + 255 * 0.88);
  const b = Math.round(parseInt(h.substring(4, 6), 16) * 0.12 + 255 * 0.88);
  return `${r} ${g} ${b}`;
}

const cssVars = `
  --c-primary: ${hexToRgbTriplet(primaryHex)};
  --c-primary-dark: ${primaryDarkHex ? hexToRgbTriplet(primaryDarkHex) : darken(primaryHex, 0.15)};
  --c-primary-soft: ${soften(primaryHex)};
  --c-nav: ${hexToRgbTriplet(navHex)};
  --font-display: '${fontDisplay}', Georgia, serif;
  --font-body: '${fontBody}', system-ui, -apple-system, sans-serif;
`;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  bodyClass?: string;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  image = '',
  type = 'website',
  bodyClass = '',
} = Astro.props;

const formattedTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;
const siteUrl = siteConfig.url || Astro.url.origin;
const socialImage = image?.startsWith('http') ? image : image ? new URL(image, siteUrl).toString() : '';
---

<!DOCTYPE html>
<html lang={siteConfig.language || 'pt-BR'} style={cssVars}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{formattedTitle}</title>
  <meta name="description" content={description} />
  <link rel="icon" href={siteConfig.favicon || '/favicon.svg'} />

  {gscVerificationTag && (
    gscVerificationTag.startsWith('<')
      ? <Fragment set:html={gscVerificationTag} />
      : <meta name="google-site-verification" content={gscVerificationTag} />
  )}

  <meta property="og:type" content={type} />
  <meta property="og:title" content={formattedTitle} />
  <meta property="og:description" content={description} />
  {socialImage && <meta property="og:image" content={socialImage} />}
  <meta property="og:url" content={Astro.url} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={formattedTitle} />
  <meta name="twitter:description" content={description} />
  {socialImage && <meta name="twitter:image" content={socialImage} />}

  <HeadPlugins />
</head>

<body class={bodyClass}>
  <Header />

  <main>
    <slot />
  </main>

  <Footer />

  <BodyEndPlugins />
</body>
</html>
