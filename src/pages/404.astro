---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página não encontrada" description="404 — esta página não existe">
  <div class="container-x py-20 md:py-32 text-center">
    <div class="font-display italic text-[12rem] md:text-[16rem] leading-none text-primary-soft mb-6 select-none">404</div>
    <h1 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-ink mb-4">
      Página não encontrada
    </h1>
    <p class="text-lg text-ink-muted mb-10 max-w-xl mx-auto">
      Esse endereço não bate com nada que temos por aqui. Pode ter mudado de lugar ou nunca existido.
    </p>
    <div class="flex gap-3 justify-center flex-wrap">
      <a href="/" class="btn btn-primary no-underline">Voltar pra home</a>
      <a href="/blog" class="btn btn-ghost no-underline">Ver todos os artigos</a>
    </div>
  </div>
</BaseLayout>
