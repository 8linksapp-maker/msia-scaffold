---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/sidebar/Sidebar.astro';
import { getCollection, getEntry } from 'astro:content';
import { readData } from '../lib/readData';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: any) => ({
    params: { slug: post.slug ?? post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const data = post.data;

const siteConfig = readData('siteConfig.json');
const slugify = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

function fmtDate(d: any): string {
  if (!d) return '';
  const dt = new Date(d);
  if (isNaN(dt.getTime())) return '';
  return dt.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' });
}

const readingMinutes = (() => {
  try {
    const text = (post.body || '') as string;
    const words = text.split(/\s+/).length;
    return Math.max(1, Math.round(words / 200));
  } catch { return 5; }
})();
---

<BaseLayout
  title={data.title}
  description={data.description || ''}
  image={data.cover || data.coverImage || ''}
  type="article"
>
  <article>
    <!-- Hero do post -->
    <header class="bg-surface border-b border-border">
      <div class="container-x py-12 md:py-16">
        <div class="max-w-prose-lg mx-auto">
          {data.category && (
            <a href={`/categoria/${slugify(data.category)}`} class="cat-pill no-underline mb-5 hover:opacity-80">
              {data.category}
            </a>
          )}

          <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight text-ink mb-6">
            {data.title}
          </h1>

          {data.description && (
            <p class="text-xl text-ink-muted leading-relaxed mb-6 font-display italic">
              {data.description}
            </p>
          )}

          <div class="flex items-center gap-4 text-xs uppercase tracking-wider text-ink-faint">
            <span>{fmtDate(data.pubDate || data.date)}</span>
            <span class="opacity-40">•</span>
            <span>{readingMinutes} min de leitura</span>
            {data.author && (<><span class="opacity-40">•</span><span>{data.author}</span></>)}
          </div>
        </div>
      </div>

      {(data.cover || data.coverImage) && (
        <div class="container-x pb-10">
          <img
            src={data.cover || data.coverImage}
            alt={data.title}
            class="w-full max-w-container mx-auto rounded-md aspect-[16/9] object-cover shadow-card"
            loading="eager"
          />
        </div>
      )}
    </header>

    <!-- Conteúdo + Sidebar -->
    <div class="container-x py-14">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-10">
        <div class="bg-surface rounded-md p-8 md:p-12 shadow-card">
          <div class="prose-msia max-w-none">
            <Content />
          </div>
        </div>
        <div>
          <Sidebar />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
