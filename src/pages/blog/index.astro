---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/ui/PostCard.astro';
import Sidebar from '../../components/sidebar/Sidebar.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a: any, b: any) => {
  const da = new Date(a.data.pubDate || a.data.date || 0).getTime();
  const db = new Date(b.data.pubDate || b.data.date || 0).getTime();
  return db - da;
});
---

<BaseLayout title="Blog" description="Todos os artigos">
  <div class="container-x py-10 md:py-14">
    <div class="mb-10">
      <h1 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-ink mb-2">Todos os artigos</h1>
      <p class="text-ink-muted">{posts.length} {posts.length === 1 ? 'post publicado' : 'posts publicados'}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-10">
      <div class="space-y-6">
        {posts.map((post: any, i: number) => (
          <PostCard post={post} index={i} />
        ))}
      </div>
      <div>
        <Sidebar />
      </div>
    </div>
  </div>
</BaseLayout>
