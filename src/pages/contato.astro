---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readData } from '../lib/readData';

const siteConfig = readData('siteConfig.json');
const contatoData = readData('contato.json', {});
const contact = siteConfig.contact || {};
---

<BaseLayout title="Contato" description={`Fale com ${siteConfig.name}`}>
  <div class="container-x py-14 md:py-20">
    <div class="max-w-prose-lg mx-auto">
      <div class="cat-pill mb-4">contato</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-ink mb-6">
        Vamos conversar
      </h1>
      <p class="text-xl text-ink-muted font-display italic mb-10 leading-relaxed">
        {(contatoData as any).intro || 'Tem ideia, parceria ou dúvida? Manda mensagem que respondemos.'}
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
        {contact.email && (
          <div class="bg-surface p-6 rounded-md shadow-card">
            <div class="widget-title mb-2">Email</div>
            <a href={`mailto:${contact.email}`} class="text-lg font-medium text-ink hover:text-primary">{contact.email}</a>
          </div>
        )}
        {contact.phone && (
          <div class="bg-surface p-6 rounded-md shadow-card">
            <div class="widget-title mb-2">Telefone</div>
            <a href={`tel:${contact.phone.replace(/\D/g, '')}`} class="text-lg font-medium text-ink hover:text-primary">{contact.phone}</a>
          </div>
        )}
        {contact.address && (
          <div class="bg-surface p-6 rounded-md shadow-card md:col-span-2">
            <div class="widget-title mb-2">Endereço</div>
            <p class="text-base text-ink">{contact.address}</p>
          </div>
        )}
      </div>

      <form class="bg-surface p-8 rounded-md shadow-card space-y-4" action="/api/subscribe" method="POST">
        <h2 class="font-display text-2xl font-semibold mb-2">Manda sua mensagem</h2>
        <div>
          <label class="block text-sm font-medium text-ink mb-1.5" for="name">Nome</label>
          <input type="text" id="name" name="name" required class="w-full px-4 py-2.5 border border-border rounded bg-surface focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium text-ink mb-1.5" for="email">Email</label>
          <input type="email" id="email" name="email" required class="w-full px-4 py-2.5 border border-border rounded bg-surface focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium text-ink mb-1.5" for="message">Mensagem</label>
          <textarea id="message" name="message" rows="5" required class="w-full px-4 py-2.5 border border-border rounded bg-surface focus:outline-none focus:border-primary resize-y"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">
          Enviar mensagem
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>
    </div>
  </div>
</BaseLayout>
