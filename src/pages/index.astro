---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/ui/PostCard.astro';
import Sidebar from '../components/sidebar/Sidebar.astro';
import { getCollection } from 'astro:content';
import { readData } from '../lib/readData';

const siteConfig = readData('siteConfig.json');

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a: any, b: any) => {
  const da = new Date(a.data.pubDate || a.data.date || 0).getTime();
  const db = new Date(b.data.pubDate || b.data.date || 0).getTime();
  return db - da;
});
---

<BaseLayout title={siteConfig.name} description={siteConfig.description}>
  <div class="container-x py-10 md:py-14">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-10">
      <div class="space-y-6">
        {posts.length === 0 ? (
          <div class="bg-surface rounded-md p-12 text-center shadow-card">
            <h2 class="font-display text-3xl mb-3">Sem posts ainda</h2>
            <p class="text-ink-muted">Crie o primeiro post no painel <a href="/admin" class="text-primary underline">/admin</a>.</p>
          </div>
        ) : (
          posts.map((post: any, i: number) => (
            <PostCard post={post} index={i} />
          ))
        )}
      </div>

      <div>
        <Sidebar />
      </div>
    </div>
  </div>
</BaseLayout>
