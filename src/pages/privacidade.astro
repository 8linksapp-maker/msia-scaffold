---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readData } from '../lib/readData';

const siteConfig = readData('siteConfig.json');
const privacy = readData('privacy.json', {});
---

<BaseLayout title="Política de Privacidade" description={`Política de privacidade do ${siteConfig.name}`}>
  <div class="container-x py-14 md:py-20">
    <div class="max-w-prose-lg mx-auto">
      <div class="cat-pill mb-4">legal</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-ink mb-3">
        Política de Privacidade
      </h1>
      {siteConfig.legal?.privacy_last_updated && (
        <p class="text-xs uppercase tracking-wider text-ink-faint mb-10">
          Última atualização: {siteConfig.legal.privacy_last_updated}
        </p>
      )}

      <div class="prose-msia">
        {(privacy as any).content ? (
          <Fragment set:html={(privacy as any).content} />
        ) : (
          <p>Edite essa página no painel admin em <a href="/admin/legal" class="text-primary underline">/admin/legal</a>.</p>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
