---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/ui/PostCard.astro';
import Sidebar from '../components/sidebar/Sidebar.astro';
import { getCollection } from 'astro:content';

const url = new URL(Astro.request.url);
const q = (url.searchParams.get('q') || '').trim().toLowerCase();

const allPosts = await getCollection('blog');
const results = q
  ? allPosts.filter((p: any) => {
      const t = (p.data.title || '').toLowerCase();
      const d = (p.data.description || '').toLowerCase();
      const c = (p.data.category || '').toLowerCase();
      return t.includes(q) || d.includes(q) || c.includes(q);
    })
  : [];
---

<BaseLayout title={q ? `Busca: ${q}` : 'Buscar'} description={`Resultados pra ${q}`}>
  <div class="container-x py-10 md:py-14">
    <div class="mb-10">
      <div class="cat-pill mb-3">busca</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-ink mb-2">
        {q ? `Resultados pra "${q}"` : 'O que você quer buscar?'}
      </h1>
      <p class="text-ink-muted">
        {q
          ? `${results.length} ${results.length === 1 ? 'resultado encontrado' : 'resultados encontrados'}`
          : 'Use a busca no menu pra encontrar artigos.'}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-10">
      <div class="space-y-6">
        {q && results.length === 0 && (
          <div class="bg-surface rounded-md p-12 text-center shadow-card">
            <p class="text-ink-muted text-lg">Nada encontrado pra <strong class="text-ink">"{q}"</strong>.</p>
            <p class="text-sm text-ink-faint mt-3">Tenta uma palavra diferente.</p>
          </div>
        )}
        {results.map((post: any, i: number) => (
          <PostCard post={post} index={i} />
        ))}
      </div>
      <div>
        <Sidebar />
      </div>
    </div>
  </div>
</BaseLayout>
