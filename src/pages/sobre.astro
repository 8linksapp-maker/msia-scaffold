---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readData } from '../lib/readData';

const sobreData = readData('sobre.json', {});
const siteConfig = readData('siteConfig.json');
---

<BaseLayout title="Sobre" description={`Conheça ${siteConfig.name}`}>
  <div class="container-x py-14 md:py-20">
    <div class="max-w-prose-lg mx-auto">
      <div class="cat-pill mb-4">sobre</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-ink mb-6">
        {(sobreData as any).title || `Conheça ${siteConfig.name}`}
      </h1>

      {(sobreData as any).subtitle && (
        <p class="text-xl text-ink-muted font-display italic mb-8 leading-relaxed">
          {(sobreData as any).subtitle}
        </p>
      )}

      <div class="prose-msia">
        {(sobreData as any).content ? (
          <Fragment set:html={(sobreData as any).content} />
        ) : (
          <p>Edite essa página no painel admin em <a href="/admin/sobre" class="text-primary underline">/admin/sobre</a>.</p>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
